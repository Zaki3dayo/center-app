# ============================================================
# フロントエンド（Expo）環境変数
# setup_guide.md セクション3-2 に準拠
# ============================================================

# Cloud Run バックエンド API のベース URL
# 本番：https://api.center.app
# ローカル開発：http://localhost:8080
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Firebase プロジェクト設定
# Firebase コンソール「プロジェクト設定」→「マイアプリ」から取得
# @react-native-firebase は google-services.json / GoogleService-Info.plist を使用するため
# これらの値はデバッグ/ログ目的のみ（実際の接続はネイティブ設定ファイルが担う）
EXPO_PUBLIC_FIREBASE_PROJECT_ID=

# Google Sign-In（@react-native-google-signin/google-signin）
# Firebase コンソール「Authentication」→「Sign-in method」→「Google」の「ウェブクライアント ID」
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
